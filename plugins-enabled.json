{
  "version": "1.0.0",
  "enabled_plugins": [
    "plugin_memory_vector_qdrant",
    "plugin_client_shellpy",
    "plugin_client_api",
    "plugin_database_mysql",
    "plugin_storage_googledrive",
    "plugin_search_google",
    "plugin_search_ddgs",
    "plugin_search_tavily",
    "plugin_search_xai",
    "plugin_search_brightdata",
    "plugin_proxy_llama",
    "plugin_client_slack",
    "plugin_urlextract_tavily",
    "plugin_urlextract_brightdata",
    "plugin_extract_gemini",
    "plugin_tmux",
    "plugin_claude_vscode_sessions"
