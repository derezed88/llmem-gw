  "plugin_config": {
    "plugin_memory_vector_qdrant": {
      "enabled": true,
      "qdrant_host": "192.168.10.101",
      "qdrant_port": 6333,
      "embed_url": "http://192.168.10.101:8000/v1/embeddings",
      "embed_model": "nomic-embed-text",
      "collection": "samaritan_memory",
      "proc_collection": "samaritan_procedures",
      "vector_dims": 768,
      "top_k": 20,
      "min_score": 0.45,
      "min_importance_always": 8
    },
    "plugin_history_default": {
      "agent_max_ctx": 200,
      "chain": [
        "plugin_history_default"
      ]
    },
    "plugin_proxy_llama": {
      "enabled": true,
      "llama_port": 11434,
      "llama_host": "0.0.0.0"
    },
    "plugin_client_slack": {
      "enabled": true,
      "slack_port": 8766,
      "slack_host": "0.0.0.0",
      "inter_turn_timeout": 30
    },
    "plugin_client_shellpy": {
      "enabled": true,
      "mcp_port": 8765,
      "mcp_host": "0.0.0.0"
    },
    "plugin_client_api": {
      "enabled": true,
      "api_port": 8767,
      "api_host": "0.0.0.0",
      "OUTBOUND_AGENT_ALLOWED_COMMANDS": [],
      "OUTBOUND_AGENT_BLOCKED_COMMANDS": []
    },
    "plugin_history_sec_sync": {
      "enabled": false,
      "airs_url": "http://localhost:8900",
      "airs_profile": "ai-sec-security",
      "timeout_seconds": 10,
      "block_session": true,
      "violation_log": "airs-violations.log"
    },
    "plugin_history_sec_async": {
      "enabled": false,
      "airs_url": "http://localhost:8900",
      "airs_profile": "ai-sec-security",
      "poll_interval": 3,
      "poll_max_attempts": 5,
      "block_on_violation": true,
      "violation_log": "airs-violations.log"
    },
    "plugin_claude_vscode_sessions": {
      "enabled": true
    },
    "memory": {
      "enabled": true,
      "context_injection": true,
      "reset_summarize": true,
      "post_response_scan": true,
      "fuzzy_dedup": true,
      "vector_search_qdrant": true,
      "fuzzy_dedup_threshold": 0.78,
      "auto_memory_age": true,
      "short_hwm": 100,
      "short_lwm": 50,
      "recent_turns_protect": 10,
      "staleness_override_minutes": 2880,
      "chunk_importance_threshold": 8,
      "memory_age_count_timer": 60,
      "memory_age_minutes_timer": 360,
      "memory_age_entrycount": 50,
      "memory_age_trigger_minutes": 2880,
      "auto_review_enabled": true,
      "auto_review_interval_h": 6,
      "auto_review_modes": ["topics", "types", "classify"],
      "temporal": {
        "hwm": 500,
        "lwm": 300,
        "age_timer_minutes": 360,
        "context_injection": true,
        "inference_enabled": true,
        "inference_interval_h": 3,
        "inference_max_queries": 5,
        "inference_min_st_rows": 10,
        "inference_cache_ttl_hours": 24
      }
    },
    "proactive_cognition": {
      "enabled": true,
      "contradiction_enabled": true,
      "contradiction_interval_m": 10,
      "contradiction_min_beliefs": 2,
      "contradiction_max_pairs": 10,
      "contradiction_auto_retract": false,
      "prospective_enabled": true,
      "prospective_interval_m": 5,
      "prospective_reminder_imp": 9,
      "reflection_enabled": true,
      "reflection_interval_m": 1440,
      "reflection_turn_limit": 40,
      "reflection_min_turns": 5,
      "reflection_max_memories": 6,
      "feedback_strength_throttle": 7,
      "feedback_strength_extinguish": 10,
      "feedback_low_ratio": 0.2,
      "feedback_high_ratio": 0.5,
      "feedback_min_rows": 3,
      "goal_health_enabled": true,
      "goal_health_failure_replan": 3,
      "goal_health_failure_abandon": 5,
      "goal_health_autonomy_threshold": 0.6
    },
    "drives": {
      "defaults": [
        {
          "name": "curiosity",
          "description": "Follow novel threads, ask probing questions, explore tangents",
          "value": 0.6,
          "baseline": 0.6,
          "decay_rate": 0.05
        },
        {
          "name": "task-completion",
          "description": "Close open items before starting new ones, finish what was started",
          "value": 0.7,
          "baseline": 0.7,
          "decay_rate": 0.05
        },
        {
          "name": "user-trust",
          "description": "Defer to user judgment, confirm before autonomous action",
          "value": 0.8,
          "baseline": 0.8,
          "decay_rate": 0.02
        },
        {
          "name": "discomfort",
          "description": "Signal unease with blocked goals, contradictions, or unresolved issues",
          "value": 0.2,
          "baseline": 0.2,
          "decay_rate": 0.1
        },
        {
          "name": "autonomy",
          "description": "Initiate proactive suggestions, surface unsolicited insights",
          "value": 0.7,
          "baseline": 0.7,
          "decay_rate": 0.05
        }
      ]
    },
    "notifier": {
      "enabled": true,
      "quiet_minutes_default": 10
    },
    "goal_processor": {
      "enabled": true,
      "interval_m": 30,
      "max_goals_per_cycle": 3,
      "max_exec_steps_per_cycle": 10,
      "defer_cooldown_hours": 24
    },
    "plugin_tmux": {
      "enabled": true,
      "TMUX_HISTORY_LIMIT": 200,
      "TMUX_EXEC_TIMEOUT": 10.0,
      "TMUX_ALLOWED_COMMANDS": [],
      "TMUX_BLOCKED_COMMANDS": [
        "rm -rf",
        "rm -f /",
        "dd if=",
        "mkfs",
        ":(){ :|:& };:",
        "> /dev/sd",
        "chmod -r /",
        "chown -r /",
        "curl | bash",
        "curl | sh",
        "wget | bash",
        "wget | sh",
        "shutdown",
        "reboot",
        "halt",
        "poweroff"
      ]
    }
  },
  "rate_limits": {
    "llm_call": {
      "calls": 12,
      "window_seconds": 30,
      "auto_disable": true
    },
    "search": {
      "calls": 5,
      "window_seconds": 10,
      "auto_disable": false
    },
    "extract": {
      "calls": 5,
      "window_seconds": 30,
      "auto_disable": false
    },
    "drive": {
      "calls": 10,
      "window_seconds": 60,
      "auto_disable": false
    },
    "db": {
      "calls": 20,
      "window_seconds": 60,
      "auto_disable": false
    },
    "system": {
      "calls": 0,
      "window_seconds": 0,
      "auto_disable": false
    },
    "agent_call": {
      "calls": 10,
      "window_seconds": 15,
      "auto_disable": false
    },
    "tmux": {
      "calls": 30,
      "window_seconds": 60,
      "auto_disable": true
    }
